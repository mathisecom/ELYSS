        "ggxU3inQ81g_childItem_0": "<p>460g per shoe</p>",
        "ggxU3inQ81g_childItem_1": "<p>Kevlar anti-puncture plate</p>",
        "ggxU3inQ81g_childItem_2": "<p>Built for concrete</p>",
