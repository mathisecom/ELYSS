        "ggiOnWLRQWx_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0673/2562/4490/files/Generated_Image_April_02_2026_-_2_43PM.jpg",
        "ggiOnWLRQWx_srcSet_mobile_src": "https://cdn.shopify.com/s/files/1/0673/2562/4490/files/hf_20260402.webp",
