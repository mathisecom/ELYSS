        "gg-NTnyYnag_text": "<p>15,000+</p>",
        "ggJq87taCGy_text": "<p>Per shoe</p>",
        "ggSBjvRq55R_text": "<p>Certified</p>",
        "ggTP7aCPqZt_text": "<p>Per shoe</p>",
        "ggTTICJJe_r_text": "<p>460g</p>",
        "ggTWKUF4t9L_text": "<p>Workers switched</p>",
        "ggZZTdY21Jm_text": "<p>460g</p>",
        "ggpCzFxpGAW_text": "<p>S3</p>",
        "ggtr25Ugtq9_text": "<p>&nbsp;Gel insoles. Frozen water bottles. Calf &nbsp;stretches &nbsp;before every shift. Maybe even a &nbsp;podiatrist at &nbsp;£50 a visit.<br><br><strong>&nbsp;It still comes back every morning.</strong> Because &nbsp;these fixes treat the symptom, not what's &nbsp;causing the damage 8 hours a day.</p>"
      },
